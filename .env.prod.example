SPRING_PROFILES_ACTIVE=prod
SPRING_APPLICATION_NAME=file-vault

PORT=8080
SERVER_SHUTDOWN=graceful

SPRINGDOC_API_DOCS_PATH=/v3/api-docs
SPRINGDOC_SWAGGER_UI_PATH=/swagger-ui.html

POSTGRES_DB=file_vault
POSTGRES_USER=replace-with-db-username

DATABASE_URL=jdbc:postgresql://db:5432/file_vault
DATABASE_USERNAME=replace-with-db-username

JWT_EXPIRATION_MS=3600000

CORS_ALLOWED_ORIGINS=https://replace-with-your-domain.com
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=*
CORS_MAX_AGE=3600

FILE_STORAGE_ROOT_PATH=/app/storage
FILE_UPLOAD_MAX_SIZE=10MB
FILE_UPLOAD_MAX_REQUEST_SIZE=11MB

FILE_ALLOWED_TYPES_JPG=image/jpeg
FILE_ALLOWED_TYPES_JPEG=image/jpeg
FILE_ALLOWED_TYPES_PNG=image/png
FILE_ALLOWED_TYPES_PDF=application/pdf
FILE_ALLOWED_TYPES_DOCX=application/vnd.openxmlformats-officedocument.wordprocessingml.document

FILE_CLEANUP_ENABLED=true
FILE_CLEANUP_FIXED_DELAY=PT1H
FILE_CLEANUP_ORPHAN_GRACE_PERIOD=PT24H
