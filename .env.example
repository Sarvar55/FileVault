# Non-secret Docker Compose settings.
SPRING_PROFILES_ACTIVE=prod
POSTGRES_DB=file_vault
POSTGRES_USER=user
POSTGRES_PORT=5433
APP_PORT=8080

# Keep passwords and signing keys in ./secrets, not in this file.
# Override this only when POSTGRES_DB is changed above.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/file_vault
